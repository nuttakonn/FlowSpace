{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=flowspace;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "ExpiryMinutes": 60,
    "Issuer": "flowspace",
    "Audience": "flowspace"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
